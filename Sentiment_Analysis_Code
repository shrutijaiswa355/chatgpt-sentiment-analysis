# Remove multiple spaces and replace with a single space
tweets_copy$content <- gsub("\\s+", " ", tweets_copy$content)

# Remove URLs from the "content" column
tweets_copy$content <- gsub("http\\S+|www\\S+", "", tweets_copy$content)

# Make a copy of the "content" column
tweets_copy$content_copy <- tweets_copy$content

# Remove special characters from the "content" column
tweets_copy$content_copy <- gsub("[^A-Za-z0-9 ]+", "", tweets_copy$content_copy)

# Remove hashtags from the "content" column
tweets_copy$content_copy <- gsub("#\\w+", "", tweets_copy$content_copy)

# Remove Twitter handles starting with @
