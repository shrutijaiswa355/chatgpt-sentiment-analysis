# Load the required libraries
library(tm)
library(topicmodels)

# Assuming 'tweets_copy' is the name of your data frame containing the tweets

# Step 1: Sort the data to get the 10000 most liked tweets
top_10000_liked_tweets <- tweets_copy[order(tweets_copy$like_count, decreasing = TRUE), ][1:10000, ]

# Step 2: Preprocess the text data in the 'content_copy' column
corpus <- Corpus(VectorSource(top_10000_liked_tweets$content_copy))
corpus <- tm_map(corpus, content_transformer(tolower))  # Convert to lowercase
corpus <- tm_map(corpus, removePunctuation)  # Remove punctuation
corpus <- tm_map(corpus, removeNumbers)  # Remove numbers
corpus <- tm_map(corpus, removeWords, stopwords("en"))  # Remove stopwords (optional)
corpus <- tm_map(corpus, stripWhitespace)  # Strip white spaces
corpus <- tm_map(corpus, stemDocument)  # Perform stemming (optional)
# You can add more preprocessing steps based on your specific requirements

# Step 3: Create a Document-Term Matrix (DTM)
dtm <- DocumentTermMatrix(corpus)

# Step 4: Apply LDA for topic modeling
num_topics <- 10  # You can adjust the number of topics as needed
lda_model <- LDA(dtm, k = num_topics)

# Step 5: Print the top words for each topic
top_words_per_topic <- terms(lda_model, 10)  # Change 10 to the number of top words you want to display
print(top_words_per_topic)







